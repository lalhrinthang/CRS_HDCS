// ─── Generator ───────────────────────────────────────────
generator client {
  provider = "prisma-client-js"
}

// ─── Datasource ──────────────────────────────────────────
datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

// Matches your frontend ReportCategory type
enum ReportCategory {
  traffic_accident
  fire_incident
  explosion
  gunfire
  protest
  arrest_activity
  patrol_presence
  road_inspection
  road_blockage
  military_checkpoint
  police_checkpoint
  traffic_police_checkpoint
  forced_conscription_activity
  restricted_area
  Other
}

// Matches your frontend ReportStatus type
enum ReportStatus {
  active
  archived
}

// User roles for access control
enum UserRole {
  USER
  ADMIN
}

// ─── Models ──────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String   // Will store hashed password (bcrypt)
  name      String
  role      UserRole @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationship: A user can create many reports
  reports Report[]

  @@map("users") // Table name in PostgreSQL will be "users"
}

model Township {
  id        String   @id @default(uuid())
  name      String   @unique
  latitude  Float
  longitude Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationship: A township can have many reports
  reports Report[]
  @@map("townships")
  accessTokens AccessToken[]
}

model Report {
  id          String         @id @default(uuid())
  title       String
  description String
  category    ReportCategory
  status      ReportStatus   @default(active)
  latitude    Float
  longitude   Float
  photoUrl    String?        // Optional (the ? means nullable)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  // Foreign Keys — links this report to a user and township
  authorId   String
  author     User     @relation(fields: [authorId], references: [id])

  townshipId String
  township   Township @relation(fields: [townshipId], references: [id])

  @@map("reports")
  accessTokenId String?
  accessToken   AccessToken? @relation("TokenReports", fields: [accessTokenId], references: [id])
}

model AccessToken {
  id          String   @id @default(cuid())
  token       String   @unique        // e.g. "crs-ygn-thanlyin-1"
  label       String                  // e.g. "Thanlyin Community Lead"
  townshipId  String?                 // links to a township (optional)
  township    Township? @relation(fields: [townshipId], references: [id])
  isActive    Boolean  @default(true) // flip to false to revoke access
  createdAt   DateTime @default(now())

  reports     Report[] @relation("TokenReports")
}